<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>            <string>org.fluxpeer.daemon</string>
  <!-- Brings up every joined network + the local control API the GUI drives. -->
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/fluxpeer</string>
    <string>up</string>
  </array>
  <key>RunAtLoad</key>        <true/>
  <key>KeepAlive</key>        <true/>
  <key>ThrottleInterval</key> <integer>5</integer>
  <key>StandardOutPath</key>  <string>/var/log/fluxpeer.log</string>
  <key>StandardErrorPath</key><string>/var/log/fluxpeer.log</string>
</dict>
</plist>
